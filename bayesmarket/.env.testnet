# BayesMarket — Testnet Configuration
# Copy to .env: cp .env.testnet .env
# Then fill in HL_PRIVATE_KEY and HL_ACCOUNT_ADDRESS

# ── DEPLOYMENT ────────────────────────────────────────
DEPLOYMENT_ENV=railway    # or: vps / local
LIVE_MODE=true
SIMULATED_CAPITAL=1000.0

# ── ASSET ─────────────────────────────────────────────
COIN=BTC
BINANCE_SYMBOL=BTCUSDT

# ── HYPERLIQUID TESTNET ───────────────────────────────
# Step 1: Ensure mainnet account activated (deposited once on mainnet)
# Step 2: Get mock USDC → https://app.hyperliquid-testnet.xyz/drip
# Step 3: Create testnet API wallet → https://app.hyperliquid-testnet.xyz/API
HL_REST_URL=https://api.hyperliquid-testnet.xyz
HL_WS_URL=wss://api.hyperliquid-testnet.xyz/ws
HL_PRIVATE_KEY=
HL_ACCOUNT_ADDRESS=

# ── TELEGRAM ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── DATABASE ──────────────────────────────────────────
# Separate DB from shadow/mainnet — never mix
DB_PATH=/app/data/bayesmarket_testnet.db
