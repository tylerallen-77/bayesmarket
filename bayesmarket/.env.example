# ════════════════════════════════════════════════════════
# BayesMarket Environment Configuration
# ════════════════════════════════════════════════════════
# Copy file ini ke .env dan isi value yang diperlukan.
# cp .env.example .env

# ── MODE ──────────────────────────────────────────────
# false = shadow mode (default, aman)
# true  = live mode (order nyata — pastikan credentials diisi)
# Bisa diubah saat runtime via Telegram /live dan /shadow
LIVE_MODE=false

# Modal simulasi untuk shadow mode
SIMULATED_CAPITAL=1000.0

# ── ASSET ─────────────────────────────────────────────
COIN=BTC
BINANCE_SYMBOL=BTCUSDT

# ── TELEGRAM ──────────────────────────────────────────
# Wajib untuk control panel Telegram.
#
# Cara mendapatkan TOKEN:
#   1. Buka Telegram → cari @BotFather
#   2. Kirim /newbot
#   3. Ikuti instruksi → copy token di bawah
#
# Cara mendapatkan CHAT_ID:
#   1. Buka Telegram → cari @userinfobot
#   2. Kirim /start → bot akan reply dengan ID kamu
#   Atau: kirim pesan ke bot kamu, lalu buka:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── HYPERLIQUID CREDENTIALS ──────────────────────────
# Tidak diperlukan untuk shadow mode.
# Wajib untuk live mode.
#
# REKOMENDASI: Gunakan API Wallet (bukan main wallet)
#   Login → app.hyperliquid.xyz/API → Create API Wallet
#   API Wallet bisa trade tapi TIDAK BISA withdraw.
#   HL_PRIVATE_KEY = private key API wallet
#   HL_ACCOUNT_ADDRESS = alamat MAIN wallet kamu (bukan API wallet)
HL_PRIVATE_KEY=
HL_ACCOUNT_ADDRESS=

# ── DATABASE ──────────────────────────────────────────
# Path ke SQLite database. Default: bayesmarket.db di working dir.
DB_PATH=bayesmarket.db

# ── TESTNET MODE ──────────────────────────────────────
# Step 1: Mainnet account must be activated (deposited once)
# Step 2: Get mock USDC → https://app.hyperliquid-testnet.xyz/drip
# Step 3: Create testnet API wallet → https://app.hyperliquid-testnet.xyz/API
# Step 4: Set these vars:
# LIVE_MODE=true
# HL_REST_URL=https://api.hyperliquid-testnet.xyz
# HL_WS_URL=wss://api.hyperliquid-testnet.xyz/ws
# HL_PRIVATE_KEY=<testnet API wallet private key>
# HL_ACCOUNT_ADDRESS=<testnet main wallet address>
# DB_PATH=/app/data/bayesmarket_testnet.db
