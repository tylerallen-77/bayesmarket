# BayesMarket — Railway Environment Template
# Set these in Railway Dashboard → Service → Variables
# Do NOT commit this file with real values

# ── DEPLOYMENT ────────────────────────────────────────
DEPLOYMENT_ENV=railway
LIVE_MODE=false
SIMULATED_CAPITAL=1000.0

# ── ASSET ─────────────────────────────────────────────
COIN=BTC
BINANCE_SYMBOL=BTCUSDT

# ── DATABASE ──────────────────────────────────────────
# Railway Volume must be mounted at /app/data
# Set mount path in Railway Dashboard → Service → Volumes → Mount Path: /app/data
DB_PATH=/app/data/bayesmarket.db

# ── TELEGRAM ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── HYPERLIQUID ───────────────────────────────────────
# Shadow mode: leave empty
# Live/Testnet: fill in
HL_REST_URL=https://api.hyperliquid.xyz
HL_WS_URL=wss://api.hyperliquid.xyz/ws
HL_PRIVATE_KEY=
HL_ACCOUNT_ADDRESS=
